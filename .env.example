# Copy to .env (same directory as docker-compose.yml) and fill in.
# docker-compose reads this automatically.

# Google OAuth (Milestone 0.2) — create OAuth clients in Google Cloud Console.
# This must be the *Web application* client ID (the mobile app's
# GoogleSignin.configure webClientId must match it).
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
